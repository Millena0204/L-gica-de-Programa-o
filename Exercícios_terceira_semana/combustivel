#include <stdio.h> 
int main() { 
    float tempo, velocidade, distancia, litros; 
    printf("Digite o tempo gasto na viagem (em horas): "); 
    scanf("%f", &tempo); 
    printf("Digite a velocidade média durante a viagem (em km/h): "); 
    scanf("%f", &velocidade); 
    distancia = tempo * velocidade; 
    litros = distancia / 12; 
    printf("\nVelocidade média: %.2f km/h", velocidade); 
    printf("\nTempo gasto: %.2f horas", tempo); 
    printf("\nDistância percorrida: %.2f km", distancia); 
    printf("\nLitros de combustível utilizados: %.2f L\n", litros); 
    return 0; 
}
