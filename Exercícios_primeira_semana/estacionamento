algoritmo "Estacionamento" 
var 
HE, ME : inteiro      
HS, MS : inteiro  
tempoMin : inteiro 
saída: inteiro  
horas : inteiro 
PAG : real 
inicio 
 
   escreva("Hora de entrada: ") 
   leia(HE) 
 
   escreva("Minuto de entrada: ") 
   leia(ME) 
 
   escreva("Hora de saída: ") 
   leia(HS) 
 
   escreva("Minuto de saída: ") 
   leia(MS) 
 
   // Converter para minutos 
   entrada <- HE * 60 + ME 
   saida <- HS * 60 + MS 
 
   // Tempo total em minutos 
   tempoMin <- saida - entrada 
 
   // Converter para horas  
   horas <- tempoMin div 60 
   se (tempoMin mod 60 > 0) entao 
      horas <- horas + 1 
   fimse 
 
   // Calcular valor a pagar 
   se (horas <= 1) entao 
      PAG <- 4.00 
   senao 
      se (horas = 2) entao 
         PAG <- 6.00 
      senao 
         PAG <- 6.00 + (horas - 2) * 1.00 
      fimse 
   fimse 
 
   escreval("Valor a pagar: R$ ", PAG:0:2) 
 
fimalgoritmo
